{
  "schemaVersion": 1,
  "cases": [
    {
      "id": "eval-product-truth-topic",
      "description": "The product-truth topic should return the agentic commerce article.",
      "query": { "topic": "product-truth" },
      "expected": {
        "slugs": ["agentic-commerce-product-truth"],
        "notSlugs": ["agent-auditable-research"]
      }
    },
    {
      "id": "eval-ai-native-publishing-topic",
      "description": "The ai-native-publishing topic should return the auditable research article.",
      "query": { "topic": "ai-native-publishing" },
      "expected": {
        "slugs": ["agent-auditable-research"],
        "notSlugs": ["agentic-commerce-product-truth"]
      }
    },
    {
      "id": "eval-keyword-agent",
      "description": "A keyword search for 'agent' should match both published articles.",
      "query": { "keyword": "agent" },
      "expected": {
        "slugs": ["agent-auditable-research", "agentic-commerce-product-truth"]
      }
    },
    {
      "id": "eval-draft-claims",
      "description": "Regression guard: no published article may return draft-state claims. Fails while any published article serves unverified claims; tracks the verification backlog from meta#61 / site#114.",
      "query": { "claimState": "draft", "status": "published" },
      "expected": {
        "slugs": [],
        "maxResults": 0
      }
    },
    {
      "id": "eval-related-to-auditable-research",
      "description": "The agentic commerce article is related to the auditable research article via the related graph edge.",
      "query": { "relatedTo": "agent-auditable-research" },
      "expected": {
        "slugs": ["agentic-commerce-product-truth"],
        "notSlugs": ["agent-auditable-research"]
      }
    }
  ]
}
