    {
      "id": "claim-001",
      "claim": "India's digital-access success has created an attention-extraction economy that diverts time and talent away from learning, creation, and civic problem-solving, but the same infrastructure could be redirected toward substance if individuals, platforms, and policymakers make different choices.",
      "confidence": "high",
      "status": "framing",
      "evidence": [
        {
          "sourceId": "source-iamai-kantar-2024",
          "snippet": "The Internet in India Report 2024 documents near-ubiquitous digital access and a usage mix dominated by entertainment and social media.",
          "supports": "direct",
          "assessedAt": "2026-07-05"
        },
        {
          "sourceId": "source-aser-2024",
          "snippet": "ASER 2024 finds that 76% of 14–16-year-olds use smartphones for social media while 57% use them for education.",
          "supports": "direct",
          "assessedAt": "2026-07-05"
        }
      ],
      "counterevidence": [
        {
          "summary": "Educational and civic uses of the same infrastructure are growing, and access itself is a precondition for productive use; the gap is shaped by design and incentives, not only by access.",
          "assessedAt": "2026-07-05"
        }
      ]
    }
