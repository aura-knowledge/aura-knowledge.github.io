{
  "name": "@aura-knowledge/site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run generate && astro build",
    "preview": "astro preview",
    "generate": "node scripts/generate-agent-index.mjs",
    "validate": "node scripts/validate-content.mjs",
    "validate:evidence": "node scripts/validate-content.mjs",
    "validate:build": "node scripts/validate-build.mjs",
    "verify": "node scripts/verify-claims.mjs",
    "agent:record": "node scripts/record-agent-run.mjs",
    "workspace:create": "node scripts/create-workspace.mjs",
    "source:import": "node scripts/source-importer.mjs",
    "source:promote": "node scripts/promote-source.mjs",
    "audit": "node scripts/audit-draft.mjs",
    "scout": "node scripts/scout-sources.mjs",
    "garden:query": "node scripts/garden-query.mjs",
    "garden:query:smoke": "node scripts/garden-query.mjs --help >/dev/null && node scripts/garden-query.mjs --topic product-truth --format ids",
    "eval:briefs": "node scripts/eval-briefs.mjs",
    "check": "npm run generate && npm run validate && astro build && npm run validate:build && npm run garden:query:smoke && npm run eval:briefs"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "astro": "^6.4.7",
    "js-yaml": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
