---
import BaseLayout from "../layouts/BaseLayout.astro";
import RoadmapCard from "../components/RoadmapCard.astro";
import roadmap from "../../content/roadmap/awesome-llm-apps-roadmap.json";

const base = import.meta.env.BASE_URL;
const sourceBase = `${roadmap.sourceRepo.url}/tree/${roadmap.sourceRepo.commit}`;
const reportUrl =
  "https://github.com/aura-knowledge/aura-knowledge.github.io/blob/main/docs/research/2026-06-17-awesome-llm-apps-roadmap.md";
const priorities = [
  { id: "P0", label: "Foundation", count: roadmap.priorityCounts.P0 },
  { id: "P1", label: "Near term", count: roadmap.priorityCounts.P1 },
  { id: "P2", label: "Later", count: roadmap.priorityCounts.P2 }
];
const ideaById = new Map(roadmap.ideas.map((idea) => [idea.id, idea]));
---

<BaseLayout
  title="Build Roadmap"
  description="A research-backed roadmap for the AI-native knowledge garden."
>
  <div class="page-shell utility-page roadmap-page">
    <header class="utility-hero roadmap-hero">
      <p class="eyebrow">Build artifact</p>
      <h1>{roadmap.title}</h1>
      <p class="lede">{roadmap.summary}</p>
      <p class="lede-note">
        This page is for people inspecting how the garden is being built. It is not part of the
        main reading path.
      </p>
      <div class="roadmap-actions" aria-label="Roadmap artifacts">
        <a class="button primary" href={reportUrl}>Research report</a>
        <a class="button" href={`${base}evidence-canvas/`}>Evidence canvas</a>
        <a class="button" href={roadmap.sourceRepo.url}>Source repo</a>
        <a class="button" href={`${base}agents/roadmap/${roadmap.slug}.json`}>
          Agent JSON
        </a>
      </div>
    </header>

    <section class="roadmap-snapshot" aria-label="Roadmap snapshot">
      <article>
        <span>Reviewed</span>
        <strong>{roadmap.updatedAt}</strong>
        <p>{roadmap.sourceRepo.name} at {roadmap.sourceRepo.commit}</p>
      </article>
      {priorities.map((priority) => (
        <article>
          <span>{priority.id}</span>
          <strong>{priority.count}</strong>
          <p>{priority.label} ideas</p>
        </article>
      ))}
    </section>

    <section class="section-band section-grid" aria-labelledby="roadmap-thesis">
      <div>
        <p class="eyebrow">Synthesis</p>
        <h2 id="roadmap-thesis">Strengthen the research object before adding runtime agency.</h2>
      </div>
      <div>
        <p>{roadmap.thesis}</p>
        <ul class="signal-list">
          {roadmap.principles.slice(0, 4).map((principle) => <li>{principle}</li>)}
        </ul>
      </div>
    </section>

    <section class="section-band" aria-labelledby="phase-title">
      <div class="roadmap-section-head">
        <p class="eyebrow">Sequence</p>
        <h2 id="phase-title">Four phases, each with a concrete artifact outcome.</h2>
      </div>
      <div class="phase-lane">
        {roadmap.phases.map((phase, index) => (
          <RoadmapCard variant="phase" phase={phase} index={index} ideaById={ideaById} />
        ))}
      </div>
    </section>

    <section class="section-band" aria-labelledby="ideas-title">
      <div class="roadmap-section-head">
        <p class="eyebrow">Product ideas</p>
        <h2 id="ideas-title">Buildable slices from the research pass.</h2>
      </div>
      <div class="idea-grid">
        {roadmap.ideas.map((idea) => (
          <RoadmapCard variant="idea" idea={idea} sourceBase={sourceBase} />
        ))}
      </div>
    </section>

    <section class="section-band section-grid" aria-labelledby="review-title">
      <div>
        <p class="eyebrow">Review</p>
        <h2 id="review-title">Cross-agent review treated runtime UI as a later layer.</h2>
      </div>
      <div>
        <p>{roadmap.crossAgentReview.notes}</p>
        <ul class="signal-list">
          {roadmap.crossAgentReview.reviewers.map((reviewer) => <li>{reviewer}</li>)}
        </ul>
      </div>
    </section>
  </div>
</BaseLayout>
