---
import BaseLayout from "../layouts/BaseLayout.astro";
import EmptyState from "../components/EmptyState.astro";
import ClaimCard from "../components/ClaimCard.astro";
import { getArticles, getTopicEntries } from "../lib/content";

const base = import.meta.env.BASE_URL;
const articles = getArticles();
const latest = articles[0] ?? null;
const topicEntries = getTopicEntries(articles)
  .sort((left, right) => right[1].length - left[1].length || left[0].localeCompare(right[0]))
  .slice(0, 8);
const claimCount = articles.reduce((total, article) => total + article.artifact.claims.length, 0);
const sourceIds = new Set(
  articles.flatMap((article) => article.artifact.sources.map((source) => source.id))
);
const latestClaims = latest?.artifact.claims ?? [];
const latestSourceById = new Map(
  latest?.artifact.sources.map((source) => [source.id, source]) ?? []
);
const pageSections = [
  { id: "overview", label: "Overview" },
  { id: "how-to-read", label: "How to read" },
  { id: "latest", label: "Latest" },
  { id: "evidence-trail", label: "Evidence trail" },
  { id: "threads", label: "Threads" },
  { id: "records", label: "Records" }
];
const readingPaths = [
  {
    label: "Articles",
    title: "Browse the archive",
    text: "Use the article index when you want the complete reading list by date.",
    href: `${base}articles/`,
    meta: `${articles.length} essays`
  },
  {
    label: "Topics",
    title: "Follow a thread",
    text: "Use topics after an article gives you a direction, not as the front door.",
    href: `${base}topics/`,
    meta: `${topicEntries.length} visible threads`
  },
  {
    label: "Graph",
    title: "Inspect relationships",
    text: "Open the graph when you want claims, sources, and links across articles.",
    href: `${base}graph/`,
    meta: `${claimCount} claims`
  }
];
---

<BaseLayout
  title="Aura Knowledge"
  description="A focused AI-era knowledge garden for human-readable essays and agent-auditable research artifacts."
>
  <div class="page-shell home-shell">
    <div class="home-content" aria-label="Aura Knowledge home">
      <section class="home-hero" id="overview" data-page-section aria-labelledby="home-title">
        <div class="home-hero-copy">
          <p class="eyebrow">Aura Knowledge</p>
          <h1 id="home-title">Essays you can read. Claims you can inspect.</h1>
          <p class="lede">
            Start with the article. Each essay carries an evidence trail with claims, sources,
            confidence, counterpoints, and provenance notes.
          </p>
          <p class="lede-note">
            AURA keeps the readable idea and its review record connected, so you can move from
            argument to evidence without losing the thread.
          </p>
          <p class="reader-note">
            Reader route: read the essay, inspect claims when needed, then branch.
          </p>
          {!latest && (
            <EmptyState
              heading="Nothing here yet"
              headingLevel={2}
              message="No published articles yet. Check back soon or open the roadmap."
            />
          )}
          <div class="button-row" aria-label="Primary actions">
            {latest && (
              <a class="button primary" href={`${base}articles/${latest.slug}/`}>
                Read the latest article
              </a>
            )}
            <a class="button" href={`${base}articles/`}>All articles</a>
            <a class="button" href={`${base}graph/`}>Evidence graph</a>
          </div>
        </div>

      </section>

      <section class="reader-guide" id="how-to-read" data-page-section aria-labelledby="reader-guide-title">
        <div class="reader-guide-copy">
          <p class="eyebrow">For human readers</p>
          <h2 id="reader-guide-title">How to read an Aura article.</h2>
          <p>
            Aura pages are written for reading. The evidence layer is for moments when you want
            confidence, a source trail, or a path into adjacent ideas.
          </p>
        </div>
        <ol class="reader-guide-steps">
          <li>
            <strong>Start with the essay.</strong>
            <span>Follow the thesis, examples, and argument before opening supporting structures.</span>
          </li>
          <li>
            <strong>Inspect one claim.</strong>
            <span>Use the packet for evidence, counterpoints, confidence, and review state.</span>
          </li>
          <li>
            <strong>Branch with intent.</strong>
            <span>Open topics, related articles, or the graph after you know what thread you want.</span>
          </li>
        </ol>
      </section>

      <section class="section-band garden-feature" id="latest" data-page-section aria-labelledby="latest-title">
      <div>
        <p class="eyebrow">Latest article</p>
        <h2 id="latest-title">Start here.</h2>
      </div>
      {latest ? (
        <article class="latest-plot">
          <div>
            <p>{latest.maturity} / {latest.topic.replaceAll("-", " ")}</p>
            <h3>
              <a href={`${base}articles/${latest.slug}/`}>{latest.title}</a>
            </h3>
            <span>{latest.summary}</span>
          </div>
          <dl>
            <div>
              <dt>Claims</dt>
              <dd>{latest.artifact.claims.length}</dd>
            </div>
            <div>
              <dt>Sources</dt>
              <dd>{latest.artifact.sources.length}</dd>
            </div>
            <div>
              <dt>Packet</dt>
              <dd>JSON + brief</dd>
            </div>
          </dl>
        </article>
      ) : (
        <div>
          <EmptyState
            heading="No articles yet"
            headingLevel={3}
            message="No articles have been published yet. Check back soon, or follow the organization page to learn how new essays are added."
            action={{ href: `${base}organization/`, text: "About the garden" }}
          />
        </div>
      )}
      </section>

      <section class="home-claim-section" id="evidence-trail" data-page-section aria-labelledby="home-claim-title">
        <div class="home-claim-head">
          <div>
            <p class="eyebrow">Evidence trail</p>
            <h2 id="home-claim-title">Every major claim has a packet.</h2>
            <p>
              A claim packet is the compact record behind a statement: evidence, counterpoints,
              confidence, status, and review state. Use it when you want to verify, not before you read.
            </p>
          </div>
          {latestClaims.length > 0 && (
            <div class="claim-audit-controls" aria-label="Scroll evidence packets">
              <button type="button" data-claim-carousel-prev aria-label="Previous evidence packet">&lsaquo;</button>
              <button type="button" data-claim-carousel-next aria-label="Next evidence packet">&rsaquo;</button>
            </div>
          )}
        </div>
        {latest && latestClaims.length > 0 ? (
          <>
            <div class="home-claim-context">
              <span>Packet preview from latest article</span>
              <a href={`${base}articles/${latest.slug}/`}>{latest.title}</a>
            </div>
            <div class="claim-audit-grid home-claim-grid" data-claim-carousel tabindex="0" role="region" aria-label="Evidence trail claim packet cards">
              {latestClaims.map((claim) => (
                <ClaimCard claim={claim} sourceById={latestSourceById} />
              ))}
            </div>
          </>
        ) : (
          <EmptyState
            heading="No evidence trail yet"
            headingLevel={3}
            message="Evidence packets appear here after a published article has structured claims."
            action={{ href: `${base}articles/`, text: "Browse articles" }}
          />
        )}
      </section>

      <section class="garden-entry-grid" aria-labelledby="paths-title">
      <header class="section-intro">
        <p class="eyebrow">Continue reading</p>
        <h2 id="paths-title">Use structure after the article gives you a direction.</h2>
      </header>
      {readingPaths.map((path) => (
        <article class="entry-path-card">
          <p>{path.label}</p>
          <h3>
            <a href={path.href}>{path.title}</a>
          </h3>
          <span>{path.text}</span>
        </article>
      ))}
      </section>

      <section class="section-band topic-branch-section" id="threads" data-page-section aria-labelledby="topics-title">
      <div>
        <p class="eyebrow">Reading threads</p>
        <h2 id="topics-title">Topics are a secondary index, not the map.</h2>
        <p>
          Use these labels after you have a direction. They are useful for resurfacing related
          essays, but they should not be the first thing a reader has to decode.
        </p>
      </div>
      {topicEntries.length > 0 ? (
        <div class="topic-branch-grid">
          {topicEntries.map(([topic, topicArticles]) => (
            <a class="topic-branch" href={`${base}topics/${topic}/`}>
              <span>{topicArticles.length} article{topicArticles.length === 1 ? "" : "s"}</span>
              <strong>{topic.replaceAll("-", " ")}</strong>
            </a>
          ))}
        </div>
      ) : (
        <EmptyState
          heading="No reading threads yet"
          headingLevel={3}
          message="Reading threads are generated from published article artifacts."
          action={{ href: `${base}articles/`, text: "Browse articles" }}
        />
      )}
      </section>

      <section class="section-band record-grid" id="records" data-page-section aria-labelledby="records-title">
      <header class="section-intro">
        <p class="eyebrow">Records</p>
        <h2 id="records-title">Utilities and structured records stay below the reading path.</h2>
      </header>
      <article class="record-card">
        <p>Evidence</p>
        <h3>Claims and sources stay visible when needed.</h3>
        <span>{claimCount} claims and {sourceIds.size} unique source records are exposed through article pages and graph data.</span>
        <a class="packet-link" href={`${base}graph/`}>Open the claims graph</a>
      </article>
      <article class="record-card">
        <p>About</p>
        <h3>The operating model has its own page.</h3>
        <span>Organization, repository, publication rules, and internal planning links stay outside the reading path.</span>
        <a class="packet-link" href={`${base}organization/`}>Open the about page</a>
      </article>
      <article class="record-card">
        <p>Agents</p>
        <h3>Automation gets a separate entrance.</h3>
        <span>Compact feeds, packet indexes, and graph files support agents without dominating the reader interface.</span>
        <a class="packet-link" href={`${base}agents/`}>Browse agent JSON feeds</a>
      </article>
      </section>
    </div>

    <nav class="page-index" aria-label="On this page">
      <span>On this page</span>
      {pageSections.map((section) => (
        <a href={`#${section.id}`} data-page-index-link>{section.label}</a>
      ))}
    </nav>
  </div>
  <script src={`${base}scripts/focus.js`} defer></script>
  <script src={`${base}scripts/page-index.js`} defer></script>
</BaseLayout>
