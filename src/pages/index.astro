---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getArticles } from "../lib/content";

const base = import.meta.env.BASE_URL;
const articles = getArticles();
const latest = articles[0];
---

<BaseLayout
  title="Aura Knowledge"
  description="A focused AI-era knowledge garden for human-readable essays and agent-auditable research artifacts."
>
  <div class="page-shell">
    <section class="home-hero" aria-labelledby="home-title">
      <div>
        <p class="eyebrow">Aura Knowledge</p>
        <h1 id="home-title">Guided for humans. Structured for agents.</h1>
        <p class="lede">
          A knowledge garden where essays are written for people first, then backed by claim maps,
          evidence ledgers, and machine-readable artifacts that agents can inspect.
        </p>
        <div class="button-row" aria-label="Primary actions">
          <a class="button primary" href={`${base}articles/${latest.slug}/`}>
            Read the latest article
          </a>
          <a class="button" href={`${base}topics/`}>Browse topics</a>
          <a class="button" href={`${base}articles/`}>All articles</a>
          <a class="button" href={`${base}roadmap/`}>Roadmap</a>
        </div>
      </div>

      <aside class="stem-panel" aria-label="Knowledge stem preview">
        <div class="stem-node">
          <div>
            <strong>Start here</strong>
            <span>Read the latest essay, or browse topics to follow an idea.</span>
          </div>
        </div>
        <div class="stem-node">
          <div>
            <strong>Read deeper</strong>
            <span>Each article carries claim markers, evidence, and related reading.</span>
          </div>
        </div>
        <div class="stem-node">
          <div>
            <strong>For agents</strong>
            <span>JSON packets, claim graphs, and compact feeds live behind the Agent entry.</span>
          </div>
        </div>
      </aside>
    </section>

    <section class="section-band section-grid" aria-labelledby="shape-title">
      <div>
        <p class="eyebrow">Publishing shape</p>
        <h2 id="shape-title">The garden is not a feed.</h2>
      </div>
      <div>
        <p>
          A feed rewards recency. This site rewards return visits to an evolving idea. Humans browse
          by topic, read a focused argument, then follow related claims. Agents use the same
          underlying artifacts without the human UI taking a back seat.
        </p>
        <ul class="signal-list">
          <li>Humans browse topics and articles first; agent surfaces are reachable but secondary.</li>
          <li>Each article exposes claim markers, evidence, and related reading inside the prose.</li>
          <li>Agents get structured metadata, claim IDs, source IDs, and compact index files.</li>
        </ul>
      </div>
    </section>

    <section class="section-band section-grid" aria-labelledby="latest-title">
      <div>
        <p class="eyebrow">Latest path</p>
        <h2 id="latest-title">Start with the source object.</h2>
      </div>
      <div class="article-list">
        {articles.map((article) => (
          <article class="article-teaser">
            <p>{article.maturity} / {article.topic.replaceAll("-", " ")}</p>
            <h3>
              <a href={`${base}articles/${article.slug}/`}>{article.title}</a>
            </h3>
            <span>{article.summary}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="section-band section-grid" aria-labelledby="roadmap-title">
      <div>
        <p class="eyebrow">Future path</p>
        <h2 id="roadmap-title">The roadmap starts with evidence, not runtime chat.</h2>
      </div>
      <div>
        <p>
          A review of runnable LLM app patterns points to a practical sequence: stronger claim
          packets, evidence diagnostics, author workspaces, source intake, and then agent-native
          inspectors once the artifact contract is stable.
        </p>
        <a class="packet-link" href={`${base}roadmap/`}>Open the roadmap</a>
      </div>
    </section>

    <section class="section-band section-grid machine-band" aria-labelledby="machines-title">
      <div>
        <p class="eyebrow">For machines</p>
        <h2 id="machines-title">Agent-native artifacts live here too.</h2>
      </div>
      <div>
        <p>
          The same content that powers the human pages is exposed as JSON packets, claim graphs, and
          compact feeds. Agents can start at the entry point and fetch only what they need.
        </p>
        <div class="button-row">
          <a class="button" href={`${base}agents/`}>Agent entry</a>
          <a class="button" href={`${base}graph/`}>Claim graph</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
