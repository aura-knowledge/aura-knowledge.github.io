---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getArticles, getSeriesEntries, getStandaloneArticles, getYearEntries } from "../../lib/content";

const base = import.meta.env.BASE_URL;
const articles = getArticles();
const seriesEntries = getSeriesEntries(articles);
const standaloneArticles = getStandaloneArticles(articles);
const totalSeriesArticles = seriesEntries.reduce((total, series) => total + series.articles.length, 0);
const yearEntries = getYearEntries(articles);
---

<BaseLayout
  title="Articles"
  description="All published essays in the Aura Knowledge garden, listed by recency."
>
  <div class="page-shell utility-page">
    <header class="utility-hero">
      <p class="eyebrow">Articles</p>
      <h1>Every published essay.</h1>
      <p class="lede">
        Each article is a human-readable argument backed by a claim map, evidence ledger, and
        machine-readable artifact. Start with a reading path, the latest standalone essay, or a topic.
      </p>
      <nav class="article-view-switcher" aria-label="Article groups">
        <a href="#series-index-title">
          <span>Reading paths</span>
          <strong>{totalSeriesArticles}</strong>
        </a>
        <a href="#article-index-title">
          <span>Standalone</span>
          <strong>{standaloneArticles.length}</strong>
        </a>
        <a href="#archive-years-title">
          <span>Archives</span>
          <strong>{yearEntries.length}</strong>
        </a>
      </nav>
    </header>

    {yearEntries.length > 0 && (
      <section class="archive-years" aria-labelledby="archive-years-title">
        <p class="eyebrow">Archives</p>
        <h2 id="archive-years-title">Browse by year</h2>
        <div class="archive-year-list">
          {yearEntries.map(([year]) => (
            <a class="button" href={`${base}articles/${year}/`}>{year}</a>
          ))}
        </div>
      </section>
    )}

    {seriesEntries.length > 0 && (
      <section class="series-index" aria-labelledby="series-index-title">
        <p class="eyebrow">Reading paths</p>
        <h2 id="series-index-title">Article series</h2>
        <div class="series-index-list">
          {seriesEntries.map((series) => {
            const guide = series.articles.find((article) => article.series?.role === "guide") ?? series.articles[0];
            const chapterCount = series.articles.filter((article) => article.series?.role === "chapter").length;

            return (
              <details class="series-index-group">
                <summary class="series-index-header">
                  <div>
                    <p>
                      <span>Series</span>
                      {series.season && <span>{series.season}</span>}
                    </p>
                    <h3>{series.title}</h3>
                    <span>{guide.summary}</span>
                  </div>
                  <div class="series-index-actions">
                    <a href={`${base}articles/${guide.slug}/`}>Start reading</a>
                    <span>{chapterCount} chapter{chapterCount === 1 ? "" : "s"}</span>
                  </div>
                </summary>
                <ol class="series-entry-list">
                  {series.articles.map((article) => (
                    <li>
                      <span class="series-entry-order">
                        {article.series?.role === "guide"
                          ? "Guide"
                          : String(article.series?.order ?? 0).padStart(2, "0")}
                      </span>
                      <div>
                        <h4>
                          <a href={`${base}articles/${article.slug}/`}>{article.title}</a>
                        </h4>
                        <p>{article.summary}</p>
                      </div>
                    </li>
                  ))}
                </ol>
              </details>
            );
          })}
        </div>
      </section>
    )}

    <section class="article-index" aria-labelledby="article-index-title">
      <p class="eyebrow">Standalone</p>
      <h2 id="article-index-title">Standalone essays</h2>
      <div class="article-index-list">
        {standaloneArticles.length > 0 ? (
          standaloneArticles.map((article) => (
            <article class="article-index-card">
              <div class="article-index-meta">
                <span>{article.date}</span>
                <span>{article.readingTime}</span>
                <span class={`maturity maturity-${article.maturity}`}>{article.maturity}</span>
              </div>
              <h3>
                <a href={`${base}articles/${article.slug}/`}>{article.title}</a>
              </h3>
              <p class="article-index-topic">
                <a href={`${base}topics/#topic-${article.topic}`}>
                  {article.topic.replaceAll("-", " ")}
                </a>
              </p>
              <p class="article-index-summary">{article.summary}</p>
            </article>
          ))
        ) : (
          <EmptyState
            heading={articles.length > 0 ? "No standalone essays yet" : "No articles yet"}
            headingLevel={3}
            message={articles.length > 0
              ? "Published articles currently belong to reading paths. Standalone essays will appear here when they are published."
              : "No articles have been published yet. New essays will appear here once they are reviewed and marked published."}
            action={{ href: `${base}roadmap/`, text: "See the roadmap" }}
          />
        )}
      </div>
    </section>
  </div>
  <script>
    document.querySelectorAll(".series-index-actions a").forEach((link) => {
      link.addEventListener("click", (event) => {
        event.stopPropagation();
      });
    });
  </script>
</BaseLayout>
