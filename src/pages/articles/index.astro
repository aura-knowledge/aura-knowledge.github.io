---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getArticles, getYearEntries } from "../../lib/content";

const base = import.meta.env.BASE_URL;
const articles = getArticles();
const yearEntries = getYearEntries(articles);
---

<BaseLayout
  title="Articles"
  description="All published essays in the Aura Knowledge garden, listed by recency."
>
  <div class="page-shell utility-page">
    <header class="utility-hero">
      <p class="eyebrow">Articles</p>
      <h1>Every published essay.</h1>
      <p class="lede">
        Each article is a human-readable argument backed by a claim map, evidence ledger, and
        machine-readable artifact. Start with the latest or browse by topic.
      </p>
    </header>

    {yearEntries.length > 0 && (
      <section class="archive-years" aria-labelledby="archive-years-title">
        <p class="eyebrow">Archives</p>
        <h2 id="archive-years-title">Browse by year</h2>
        <div class="archive-year-list">
          {yearEntries.map(([year]) => (
            <a class="button" href={`${base}articles/${year}/`}>{year}</a>
          ))}
        </div>
      </section>
    )}

    <section class="article-index" aria-labelledby="article-index-title">
      <h2 id="article-index-title" class="visually-hidden">Article list</h2>
      <div class="article-index-list">
        {articles.length > 0 ? (
          articles.map((article) => (
            <article class="article-index-card">
              <div class="article-index-meta">
                <span>{article.date}</span>
                <span>{article.readingTime}</span>
                <span class={`maturity maturity-${article.maturity}`}>{article.maturity}</span>
              </div>
              <h3>
                <a href={`${base}articles/${article.slug}/`}>{article.title}</a>
              </h3>
              <p class="article-index-topic">
                <a href={`${base}topics/#topic-${article.topic}`}>
                  {article.topic.replaceAll("-", " ")}
                </a>
              </p>
              <p class="article-index-summary">{article.summary}</p>
            </article>
          ))
        ) : (
          <EmptyState
            heading="No articles yet"
            headingLevel={3}
            message="No articles have been published yet. New essays will appear here once they are reviewed and marked published."
            action={{ href: `${base}roadmap/`, text: "See the roadmap" }}
          />
        )}
      </div>
    </section>
  </div>
</BaseLayout>
