---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FocusRail from "../../components/FocusRail.astro";
import TopicChip from "../../components/TopicChip.astro";
import { getArticles } from "../../lib/content";

export function getStaticPaths() {
  return getArticles().map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const Content = article.Content;
const base = import.meta.env.BASE_URL;
const allArticles = getArticles();
const sourceById = new Map(article.artifact.sources.map((source) => [source.id, source]));
const relatedArticles = allArticles
  .filter(
    (candidate) =>
      candidate.slug !== article.slug &&
      candidate.artifact.topics.some((topic) => article.artifact.topics.includes(topic))
  )
  .slice(0, 3);
const canonicalUrl = new URL(
  `${base}${article.canonicalPath.replace(/^\/+/, "")}`,
  Astro.site ?? "https://aura-knowledge.github.io"
).toString();
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.title,
  description: article.summary,
  datePublished: article.date,
  dateModified: article.updated,
  author: {
    "@type": "Person",
    name: "Vishal Singh"
  },
  mainEntityOfPage: canonicalUrl
};
---

<BaseLayout title={article.title} description={article.summary} bodyClass="article-page">
  <div class="page-shell article-shell">
    <header class="article-hero" aria-labelledby="article-title">
      <p class="eyebrow">
        <TopicChip topic={article.topic} href={`${base}topics/#topic-${article.topic}`} />
      </p>
      <h1 id="article-title">{article.title}</h1>
      <p class="lede">{article.dek}</p>
      <div class="article-meta" aria-label="Article metadata">
        <span>{article.date}</span>
        <span>{article.readingTime}</span>
        <span>{article.maturity}</span>
      </div>
    </header>

    <div class="article-layout">
      <FocusRail claims={article.artifact.claims} />

      <article class="article-body">
        <Content />
        <section class="claim-audit" aria-labelledby="claim-audit-title">
          <p class="eyebrow">Audit layer</p>
          <h2 id="claim-audit-title">Claim packets</h2>
          <p>
            Each card is generated from the same artifact that agents consume. The essay stays
            readable; the claim packet keeps the trust layer inspectable.
          </p>
          <div class="claim-audit-grid">
            {article.artifact.claims.map((claim) => (
              <article class="claim-audit-card" id={`${claim.id}-packet`}>
                <header>
                  <span>{claim.id.replace("claim-", "C")}</span>
                  <strong>{claim.confidence}</strong>
                </header>
                <h3>{claim.claim}</h3>
                <dl>
                  <div>
                    <dt>Evidence</dt>
                    <dd>
                      {claim.evidence.slice(0, 2).map((sourceId) => {
                        const source = sourceById.get(sourceId);
                        return source ? (
                          <a href={source.url}>{source.title}</a>
                        ) : (
                          <span>{sourceId}</span>
                        );
                      })}
                    </dd>
                  </div>
                  <div>
                    <dt>Counterpoint</dt>
                    <dd>{claim.counterevidence[0] ?? "No counterpoint recorded yet."}</dd>
                  </div>
                </dl>
              </article>
            ))}
          </div>
        </section>
        <section class="source-ledger" aria-labelledby="sources-title">
          <h2 id="sources-title">Source Ledger</h2>
          <ul>
            {article.artifact.sources.map((source) => (
              <li>
                <a href={source.url}>{source.title}</a>
                <span>{source.type}</span>
              </li>
            ))}
          </ul>
        </section>

        {relatedArticles.length > 0 && (
          <section class="related-reading" aria-labelledby="related-title">
            <p class="eyebrow">Continue reading</p>
            <h2 id="related-title">Related articles</h2>
            <div class="related-reading-grid">
              {relatedArticles.map((related) => (
                <article class="related-reading-card">
                  <p>{related.topic.replaceAll("-", " ")}</p>
                  <h3>
                    <a href={`${base}articles/${related.slug}/`}>{related.title}</a>
                  </h3>
                  <p>{related.summary}</p>
                </article>
              ))}
            </div>
          </section>
        )}

        <section class="agent-packet-link" aria-labelledby="agent-packet-title">
          <h2 id="agent-packet-title">Machine-readable packet</h2>
          <p>
            The same claims, sources, and relationships are also available as a structured artifact
            for agents.
          </p>
          <div class="button-row">
            <a class="button" href={`${base}agents/articles/${article.slug}.json`}>
              Agent JSON
            </a>
            <a class="button" href={`${base}agents/articles/${article.slug}.md`}>
              Agent brief
            </a>
          </div>
        </section>
      </article>
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script src={`${base}scripts/focus.js`} defer></script>
</BaseLayout>
