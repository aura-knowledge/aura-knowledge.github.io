---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FocusRail from "../../components/FocusRail.astro";
import TopicChip from "../../components/TopicChip.astro";
import ProvenancePanel from "../../components/ProvenancePanel.astro";
import ClaimCard from "../../components/ClaimCard.astro";
import SourceLedger from "../../components/SourceLedger.astro";
import AgentPacketLink from "../../components/AgentPacketLink.astro";
import MermaidRenderer from "../../components/MermaidRenderer.astro";
import MaturityBadge from "../../components/MaturityBadge.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getArticles, getSeriesNavigation } from "../../lib/content";

export function getStaticPaths() {
  return getArticles().map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const Content = article.Content;
const base = import.meta.env.BASE_URL;
const allArticles = getArticles();
const seriesNavigation = getSeriesNavigation(article, allArticles);
const sourceById = new Map(article.artifact.sources.map((source) => [source.id, source]));
const relatedArticles = allArticles
  .filter(
    (candidate) =>
      candidate.slug !== article.slug &&
      candidate.artifact.topics.some((topic) => article.artifact.topics.includes(topic))
  )
  .slice(0, 3);
const canonicalUrl = new URL(
  `${base}${article.canonicalPath.replace(/^\/+/, "")}`,
  Astro.site ?? "https://aura-knowledge.github.io"
).toString();
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.title,
  description: article.summary,
  datePublished: article.date,
  dateModified: article.updated,
  author: {
    "@type": "Person",
    name: "Vishal Singh"
  },
  mainEntityOfPage: canonicalUrl
};
---

<BaseLayout title={article.title} description={article.summary} bodyClass="article-page">
  <div class="page-shell article-shell">
    <header class="article-hero" aria-labelledby="article-title">
      <p class="eyebrow">
        <TopicChip topic={article.topic} href={`${base}topics/#topic-${article.topic}`} />
      </p>
      <h1 id="article-title">{article.title}</h1>
      <p class="lede">{article.dek}</p>
      <div class="article-meta" aria-label="Article metadata">
        <span>{article.date}</span>
        <span>{article.readingTime}</span>
        <MaturityBadge maturity={article.maturity} />
        <StatusBadge status={article.status} />
      </div>
    </header>

    <div class="article-layout">
      <article class="article-body">
        <Content />

        {seriesNavigation && (
          <nav class="article-series-nav" aria-labelledby="article-series-nav-title">
            <div>
              <p class="eyebrow">{seriesNavigation.series.season ?? "Series"}</p>
              <h2 id="article-series-nav-title">{seriesNavigation.series.title}</h2>
              <p>
                Entry {(article.series?.order ?? 0) + 1} of {seriesNavigation.entries.length}
              </p>
            </div>
            <div class="article-series-nav-links">
              {seriesNavigation.previous ? (
                <a href={`${base}articles/${seriesNavigation.previous.slug}/`}>
                  <span>Previous</span>
                  {seriesNavigation.previous.title}
                </a>
              ) : (
                <span class="article-series-nav-empty">Start of series</span>
              )}
              {seriesNavigation.next ? (
                <a href={`${base}articles/${seriesNavigation.next.slug}/`}>
                  <span>Next</span>
                  {seriesNavigation.next.title}
                </a>
              ) : (
                <span class="article-series-nav-empty">End of series</span>
              )}
            </div>
          </nav>
        )}

        {article.artifact.claims.length > 1 && <FocusRail claims={article.artifact.claims} />}

        <SourceLedger sources={article.artifact.sources} />

        <details class="claim-audit" aria-labelledby="claim-audit-title">
          <summary class="claim-audit-heading">
            <div>
              <p class="eyebrow">Look closer</p>
              <h2 id="claim-audit-title">Sources and notes</h2>
            </div>
            <span class="claim-audit-summary-action details-state">
              <span class="when-closed">Open details</span>
              <span class="when-open">Close details</span>
            </span>
          </summary>
          <div class="claim-audit-content">
            <div class="claim-audit-controls" aria-label="Scroll source notes">
              <button type="button" data-claim-carousel-prev aria-label="Previous source note">&lsaquo;</button>
              <button type="button" data-claim-carousel-next aria-label="Next source note">&rsaquo;</button>
            </div>
            <p>
              These notes collect the sources, counterpoints, and review status behind the
              article's important points. Read the essay first; open this when you want to check
              something.
            </p>
            <p class="claim-legend">
              <strong>Confidence</strong> reflects how strongly the sources support the point
              (low / medium / high). <strong>Status</strong> describes the point's role (e.g., core,
              argument, landscape). <strong>Sources</strong> link to supporting material;
              <strong>counterpoints</strong> note boundary conditions or conflicting findings.
            </p>
            <div class="claim-audit-grid" data-claim-carousel tabindex="0" role="region" aria-label="Source note cards">
              {article.artifact.claims.map((claim) => (
                <ClaimCard claim={claim} sourceById={sourceById} />
              ))}
            </div>
          </div>
        </details>

        <ProvenancePanel provenance={article.artifact.provenance} contentHash={article.artifact.contentHash} />

        <section class="related-reading" aria-labelledby="related-title">
          <p class="eyebrow">Continue reading</p>
          <h2 id="related-title">Related articles</h2>
          {relatedArticles.length > 0 ? (
            <div class="related-reading-grid">
              {relatedArticles.map((related) => (
                <article class="related-reading-card">
                  <p>{related.topic.replaceAll("-", " ")}</p>
                  <h3>
                    <a href={`${base}articles/${related.slug}/`}>{related.title}</a>
                  </h3>
                  <p>{related.summary}</p>
                </article>
              ))}
            </div>
          ) : (
            <EmptyState
              heading="No related articles yet"
              headingLevel={3}
              message="This article doesn't have related published articles yet. Browse topics to explore more ideas."
              action={{ href: `${base}topics/`, text: "Browse topics" }}
            />
          )}
        </section>

        <AgentPacketLink slug={article.slug} base={base} />
      </article>
    </div>
  </div>
  <MermaidRenderer />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script src={`${base}scripts/focus.js`} defer></script>
</BaseLayout>
