---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getArticles, groupArticlesByYearMonth, getMonthName } from "../../../lib/content";

export function getStaticPaths() {
  const articles = getArticles();
  const yearMonths = new Set(articles.map((article) => article.date.slice(0, 7)));
  return Array.from(yearMonths).map((yearMonth) => {
    const [year, month] = yearMonth.split("-");
    return { params: { year, month } };
  });
}

const { year, month } = Astro.params;
const yearMonth = `${year}-${month}`;
const base = import.meta.env.BASE_URL;
const articles = getArticles();
const monthArticles = groupArticlesByYearMonth(articles).get(yearMonth) ?? [];
const monthName = getMonthName(yearMonth);
---

<BaseLayout
  title={`Articles from ${monthName} ${year}`}
  description={`All Aura Knowledge essays published in ${monthName} ${year}.`}
>
  <div class="page-shell utility-page">
    <header class="utility-hero">
      <p class="eyebrow">Archive</p>
      <h1>{monthName} {year}</h1>
      <p class="lede">
        {monthArticles.length} article{monthArticles.length === 1 ? "" : "s"} published in {monthName} {year}.
      </p>
      <div class="button-row">
        <a class="button" href={`${base}articles/${year}/`}>{year}</a>
        <a class="button" href={`${base}articles/`}>All articles</a>
      </div>
    </header>

    <section class="article-index" aria-labelledby="month-article-list-title">
      <h2 id="month-article-list-title" class="visually-hidden">Articles this month</h2>
      {monthArticles.length > 0 ? (
        <div class="article-index-list">
          {monthArticles.map((article) => (
            <article class="article-index-card">
              <div class="article-index-meta">
                <span>{article.date}</span>
                <span>{article.readingTime}</span>
                <span class={`maturity maturity-${article.maturity}`}>{article.maturity}</span>
              </div>
              <h3>
                <a href={`${base}articles/${article.slug}/`}>{article.title}</a>
              </h3>
              <p class="article-index-summary">{article.summary}</p>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>No articles were published in {monthName} {year}.</p>
          <a class="button" href={`${base}articles/${year}/`}>Browse {year}</a>
        </div>
      )}
    </section>
  </div>
</BaseLayout>
