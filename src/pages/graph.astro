---
import { readFileSync } from "node:fs";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getArticles, getTopicEntries, formatTopicLabel } from "../lib/content";

const base = import.meta.env.BASE_URL;
const articles = getArticles();
const topicEntries = getTopicEntries(articles);

const publicDir = path.join(process.cwd(), "public");
const nodes = JSON.parse(readFileSync(path.join(publicDir, "graph", "nodes.json"), "utf8"));
const edgesPacket = JSON.parse(readFileSync(path.join(publicDir, "graph", "edges.json"), "utf8"));
const edges = edgesPacket.edges ?? [];
const nodeById = new Map(nodes.map((node) => [node.id, node]));

function nodeLabel(id) {
  const node = nodeById.get(id);
  if (!node) return id;
  return node.label ?? node.id;
}
---

<BaseLayout
  title="Knowledge Graph"
  description="A topic and claim graph for the knowledge garden."
>
  <div class="page-shell utility-page">
    <header class="utility-hero">
      <p class="eyebrow">Graph</p>
      <h1>Browse the stems, then inspect the claims.</h1>
      <p class="lede">
        The graph is deliberately simple in the first release: topics point to articles, then each
        article exposes its claim map once. The generated JSON files expose the same map to agents.
      </p>
    </header>

    <section class="graph-stems" aria-label="Topic stems">
      {topicEntries.map(([topic, topicArticles]) => (
        <article class="graph-stem" id={`topic-${topic}`}>
          <header>
            <p class="eyebrow">Topic</p>
            <h2>{formatTopicLabel(topic)}</h2>
          </header>
          <div class="graph-topic-links">
            {topicArticles.map((article) => (
              <a href={`#${article.slug}-claims`}>{article.title}</a>
            ))}
          </div>
        </article>
      ))}
    </section>

    <section class="graph-branch-list graph-article-branches" aria-labelledby="article-claim-maps">
      <div class="roadmap-section-head">
        <p class="eyebrow">Article maps</p>
        <h2 id="article-claim-maps">Each article appears once with its claims.</h2>
      </div>
      {articles.map((article) => (
        <section class="graph-branch" id={`${article.slug}-claims`}>
          <div class="graph-article-topics" aria-label="Topics">
            {article.artifact.topics.map((topic) => (
              <a href={`#topic-${topic}`}>{formatTopicLabel(topic)}</a>
            ))}
          </div>
          <h3>
            <a href={`${base}articles/${article.slug}/`}>{article.title}</a>
          </h3>
          <p>{article.artifact.thesis}</p>
          <ol>
            {article.artifact.claims.map((claim) => (
              <li>
                <span>{claim.id.replace("claim-", "C")}</span>
                {claim.claim}
              </li>
            ))}
          </ol>
        </section>
      ))}
    </section>

    <section class="section-band" aria-labelledby="graph-edges-title">
      <div class="roadmap-section-head">
        <p class="eyebrow">Provenance</p>
        <h2 id="graph-edges-title">Graph edges and provenance</h2>
      </div>
      <p>
        Each edge is generated from the artifact at build time and carries provenance metadata.
        <code>supports</code> and <code>contests</code> edges come from evidence and counterevidence
        packets; other edge types come from <code>artifact.related</code>.
      </p>
      <ul class="graph-edge-list">
        {edges.slice(0, 50).map((edge) => (
          <li>
            <span class={`edge-type edge-type-${edge.type}`}>{edge.type}</span>
            <span>{nodeLabel(edge.from)}</span>
            <span aria-hidden="true">→</span>
            <span>{nodeLabel(edge.to)}</span>
            {edge.provenance && (
              <span class="edge-provenance">
                {edge.provenance.status} · {edge.provenance.reviewedAt}
              </span>
            )}
          </li>
        ))}
      </ul>
      {edges.length > 50 && (
        <p class="graph-edge-note">Showing 50 of {edges.length} edges. The full list is in public/graph/edges.json.</p>
      )}
    </section>
  </div>
</BaseLayout>
