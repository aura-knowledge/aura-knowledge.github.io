---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getArticles, getTopicEntries, formatTopicLabel } from "../lib/content";

const base = import.meta.env.BASE_URL;
const articles = getArticles();
const topicEntries = getTopicEntries(articles);
---

<BaseLayout
  title="Knowledge Graph"
  description="A topic and claim graph for the knowledge garden."
>
  <div class="page-shell utility-page">
    <header class="utility-hero">
      <p class="eyebrow">Graph</p>
      <h1>Browse the stems, then inspect the claims.</h1>
      <p class="lede">
        The graph is deliberately simple in the first release: topics point to articles, then each
        article exposes its claim map once. The generated JSON files expose the same map to agents.
      </p>
    </header>

    <section class="graph-stems" aria-label="Topic stems">
      {topicEntries.map(([topic, topicArticles]) => (
        <article class="graph-stem" id={`topic-${topic}`}>
          <header>
            <p class="eyebrow">Topic</p>
            <h2>{formatTopicLabel(topic)}</h2>
          </header>
          <div class="graph-topic-links">
            {topicArticles.map((article) => (
              <a href={`#${article.slug}-claims`}>{article.title}</a>
            ))}
          </div>
        </article>
      ))}
    </section>

    <section class="graph-branch-list graph-article-branches" aria-labelledby="article-claim-maps">
      <div class="roadmap-section-head">
        <p class="eyebrow">Article maps</p>
        <h2 id="article-claim-maps">Each article appears once with its claims.</h2>
      </div>
      {articles.map((article) => (
        <section class="graph-branch" id={`${article.slug}-claims`}>
          <div class="graph-article-topics" aria-label="Topics">
            {article.artifact.topics.map((topic) => (
              <a href={`#topic-${topic}`}>{formatTopicLabel(topic)}</a>
            ))}
          </div>
          <h3>
            <a href={`${base}articles/${article.slug}/`}>{article.title}</a>
          </h3>
          <p>{article.artifact.thesis}</p>
          <ol>
            {article.artifact.claims.map((claim) => (
              <li>
                <span>{claim.id.replace("claim-", "C")}</span>
                {claim.claim}
              </li>
            ))}
          </ol>
        </section>
      ))}
    </section>
  </div>
</BaseLayout>
