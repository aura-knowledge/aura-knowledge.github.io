---
import BaseLayout from "../layouts/BaseLayout.astro";
import TopicChip from "../components/TopicChip.astro";
import { getArticles, getTopicEntries } from "../lib/content";

const base = import.meta.env.BASE_URL;
const articles = getArticles();
const topicEntries = getTopicEntries(articles);
---

<BaseLayout
  title="Topics"
  description="Browse articles grouped by topic."
>
  <div class="page-shell utility-page">
    <header class="utility-hero">
      <p class="eyebrow">Topics</p>
      <h1>Browse the topic stems.</h1>
      <p class="lede">
        Articles are grouped by the topics declared in their artifacts. Each topic links to the
        articles that explore it.
      </p>
    </header>

    <section class="graph-stems" aria-label="Topic stems">
      {topicEntries.length > 0 ? (
        topicEntries.map(([topic, topicArticles]) => (
          <article class="graph-stem" id={`topic-${topic}`}>
            <header>
              <p class="eyebrow">Topic</p>
              <h2><TopicChip topic={topic} /></h2>
            </header>
            <div class="graph-topic-links">
              {topicArticles.map((article) => (
                <a href={`${base}articles/${article.slug}/`}>{article.title}</a>
              ))}
            </div>
          </article>
        ))
      ) : (
        <div class="empty-state">
          <p>
            No topics have been published yet. Topics are created from published
            articles, so new stems will appear once the first essay goes live.
          </p>
          <a class="button" href={`${base}articles/`}>Browse articles</a>
        </div>
      )}
    </section>
  </div>
</BaseLayout>
