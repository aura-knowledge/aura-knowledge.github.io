---
import BaseLayout from "../layouts/BaseLayout.astro";
import EmptyState from "../components/EmptyState.astro";
import { getArticles, getTopicEntries, formatTopicLabel } from "../lib/content";

const base = import.meta.env.BASE_URL;
const articles = getArticles();
const topicEntries = getTopicEntries(articles).sort(
  (left, right) => right[1].length - left[1].length || left[0].localeCompare(right[0])
);
---

<BaseLayout
  title="Topic Index"
  description="A secondary index of Aura Knowledge articles grouped by topic."
>
  <div class="page-shell utility-page">
    <header class="utility-hero">
      <p class="eyebrow">Topic index</p>
      <h1>A compact index, not the front door.</h1>
      <p class="lede">
        Topics are generated from published articles. They are useful once you know the thread you
        want, but the normal reading path starts with articles.
      </p>
      <div class="button-row" aria-label="Topic index starting points">
        <a class="button primary" href={`${base}articles/`}>Start with articles</a>
        <a class="button" href={`${base}graph/`}>Reading map</a>
      </div>
    </header>

    <section class="topic-index" aria-label="Topic index">
      {topicEntries.length > 0 ? (
        topicEntries.map(([topic, topicArticles]) => (
          <details class="topic-index-row" id={`topic-${topic}`}>
            <summary>
              <span>
                <strong>{formatTopicLabel(topic)}</strong>
                <small>{topicArticles.length} article{topicArticles.length === 1 ? "" : "s"}</small>
              </span>
              <span class="details-state">
                <span class="when-closed">Show articles</span>
                <span class="when-open">Hide articles</span>
              </span>
            </summary>
            <div class="topic-index-links">
              <a class="topic-index-detail-link" href={`${base}topics/${topic}/`}>View topic page</a>
              {topicArticles.map((article) => (
                <a href={`${base}articles/${article.slug}/`}>{article.title}</a>
              ))}
            </div>
          </details>
        ))
      ) : (
        <EmptyState
          heading="No topic index yet"
          headingLevel={2}
          message="Topics appear once published articles are live."
          action={{ href: `${base}articles/`, text: "Browse articles" }}
        />
      )}
    </section>
  </div>
</BaseLayout>
