---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title = "Aura Knowledge",
  description = "A focused knowledge garden for human essays and agent-readable research artifacts.",
  bodyClass = ""
} = Astro.props;

const base = import.meta.env.BASE_URL;
const pageTitle = title === "Aura Knowledge" ? title : `${title} | Aura Knowledge`;
const pathname = Astro.url.pathname;

const navItems = [
  { href: `${base}articles/`, label: "Articles" },
  { href: `${base}graph/`, label: "Evidence" },
  { href: `${base}organization/`, label: "About" }
];

const isActive = (href: string) => {
  if (href === base) {
    return pathname === base || pathname === `${base}index.html`;
  }
  return pathname === href || pathname.startsWith(href);
};
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f7f3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0d1117" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("knowledge-theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored || (prefersDark ? "dark" : "light");
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary navigation">
        <a class="brand" href={base}>
          <span class="brand-mark" aria-hidden="true">A</span>
          <span>Aura Knowledge</span>
        </a>
        <div class="nav-links">
          {navItems.map((item) => {
            const active = isActive(item.href);
            return (
              <a
                href={item.href}
                class:list={[{ "is-active": active }]}
                aria-current={active ? "page" : undefined}
              >
                {item.label}
              </a>
            );
          })}
          <ThemeToggle />
        </div>
      </nav>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer-inner">
        <span>Readable essays, auditable research packets.</span>
        <div class="footer-meta">
          <span>Structured for agents. Guided for humans.</span>
          <nav aria-label="Utility links">
            <a class="footer-utility" href={`${base}topics/`}>Topic index</a>
            <a class="footer-utility" href={`${base}roadmap/`}>Roadmap</a>
            <a class="footer-utility" href={`${base}agents/`}>Agent entry</a>
            <a class="footer-utility" href={`${base}llms.txt`}>llms.txt</a>
          </nav>
        </div>
      </div>
    </footer>
  </body>
</html>
