---
import type { ArticleArtifact } from "../lib/content";

interface Props {
  sources: ArticleArtifact["sources"];
}

const { sources } = Astro.props;
---

<details class="source-ledger" aria-labelledby="sources-title">
  <summary>
    <span>
      <span class="eyebrow">Structured sources</span>
      <strong id="sources-title">Source ledger</strong>
    </span>
    <span>{sources.length} sources</span>
  </summary>
  <ul>
    {sources.map((source) => (
      <li>
        <a href={source.url}>{source.title}</a>
        <span>{source.type}</span>
      </li>
    ))}
  </ul>
</details>
