---
import type { ArticleArtifact } from "../lib/content";

interface Props {
  claims: ArticleArtifact["claims"];
}

const { claims } = Astro.props;
---

<nav class="focus-rail" aria-labelledby="claims-title" data-focus-rail>
  <div class="reading-progress" aria-hidden="true">
    <span data-reading-progress></span>
  </div>
  <div class="focus-rail-header">
    <p class="eyebrow">Claims</p>
    <h2 id="claims-title">Article map</h2>
  </div>
  <ol>
    {claims.map((claim) => (
      <li>
        <a href={`#${claim.id}`} data-focus-link={claim.id}>
          <span>{claim.id.replace("claim-", "C")}</span>
          <strong>
            {claim.status} · {claim.confidence}
            {claim.verification && ` · ${claim.verification.status}`}
          </strong>
          <em>{claim.claim}</em>
        </a>
      </li>
    ))}
  </ol>
</nav>
