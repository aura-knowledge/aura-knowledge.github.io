---
import type { ArticleArtifact } from "../lib/content";

interface Props {
  claims: ArticleArtifact["claims"];
}

const { claims } = Astro.props;
---

<details class="focus-rail" data-focus-rail>
  <summary class="focus-rail-header">
    <span>
      <span class="focus-rail-kicker">Audit map</span>
      <strong id="claims-title">Claims and evidence</strong>
    </span>
    <span>{claims.length} claim{claims.length === 1 ? "" : "s"}</span>
  </summary>
  <ol>
    {claims.map((claim) => (
      <li>
        <a href={`#${claim.id}`} data-focus-link={claim.id}>
          <span>{claim.id.replace("claim-", "C")}</span>
          <strong>
            {claim.status} · {claim.confidence}
            {claim.verification && ` · ${claim.verification.status}`}
          </strong>
          <em>{claim.claim}</em>
        </a>
      </li>
    ))}
  </ol>
</details>
