{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://v-i-s-h-a-l.github.io/knowledge/schemas/scout-config.schema.json",
  "title": "Aura Knowledge Scout Config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "feeds"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "feeds": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "name", "type", "url", "topic"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string",
            "minLength": 2
          },
          "type": {
            "type": "string",
            "enum": ["rss", "atom"]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "topic": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "enabled": {
            "type": "boolean"
          },
          "sourceType": {
            "type": "string",
            "enum": [
              "paper",
              "article",
              "report",
              "book",
              "dataset",
              "protocol",
              "tool",
              "standard",
              "newsletter",
              "blog",
              "repository",
              "documentation",
              "inline"
            ]
          }
        }
      }
    }
  }
}
