{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://v-i-s-h-a-l.github.io/knowledge/schemas/artifact.schema.json",
  "title": "Knowledge Garden Agent Artifact",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "id",
    "slug",
    "title",
    "canonicalPath",
    "sourcePath",
    "agentBriefPath",
    "thesis",
    "status",
    "maturity",
    "publishedAt",
    "updatedAt",
    "audiences",
    "topics",
    "claims",
    "sources",
    "related",
    "agentInstructions",
    "provenance",
    "contentHash"
  ],
  "properties": {
    "schemaVersion": {
      "const": 3
    },
    "id": {
      "type": "string",
      "pattern": "^article:[a-z0-9-]+$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 8
    },
    "canonicalPath": {
      "type": "string",
      "pattern": "^/articles/[a-z0-9-]+/$"
    },
    "sourcePath": {
      "type": "string",
      "pattern": "^content/articles/\\d{4}/[a-z0-9-]+/article\\.md$"
    },
    "agentBriefPath": {
      "type": "string",
      "pattern": "^content/articles/\\d{4}/[a-z0-9-]+/agent\\.md$"
    },
    "thesis": {
      "type": "string",
      "minLength": 80
    },
    "status": {
      "enum": ["draft", "review", "published", "archived"]
    },
    "maturity": {
      "enum": ["seed", "sprout", "evergreen", "contested", "superseded"]
    },
    "publishedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "audiences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "title", "order", "role"],
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 8
        },
        "season": {
          "type": "string",
          "minLength": 3,
          "maxLength": 80
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "role": {
          "enum": ["guide", "chapter", "companion", "appendix"]
        }
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "claim", "confidence", "status", "evidence", "counterevidence"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^claim-[0-9]{3}$"
          },
          "claim": {
            "type": "string",
            "minLength": 24
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "medium-high", "high"]
          },
          "status": {
            "type": "string",
            "enum": ["core", "landscape", "forecast", "proposal", "normative", "risk", "argument", "design", "strategy", "framing", "behavioral"]
          },
          "verification": {
            "type": "object",
            "additionalProperties": true,
            "required": ["reviewedAt", "reviewer", "status"],
            "properties": {
              "reviewedAt": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "reviewer": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": ["draft", "verified", "contested", "stale"]
              }
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["sourceId", "snippet", "supports"],
              "properties": {
                "sourceId": {
                  "type": "string",
                  "pattern": "^source-[a-z0-9-]+$"
                },
                "snippet": {
                  "type": "string",
                  "minLength": 12
                },
                "supports": {
                  "type": "string",
                  "enum": ["direct", "indirect", "analogous", "background"]
                },
                "location": {
                  "type": "string"
                },
                "assessedAt": {
                  "type": "string",
                  "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                },
                "notes": {
                  "type": "string"
                }
              }
            }
          },
          "counterevidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["summary"],
              "properties": {
                "sourceId": {
                  "type": "string",
                  "pattern": "^source-[a-z0-9-]+$"
                },
                "snippet": {
                  "type": "string"
                },
                "summary": {
                  "type": "string",
                  "minLength": 12
                },
                "assessedAt": {
                  "type": "string",
                  "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                },
                "notes": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "title", "url", "type", "accessed"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^source-[a-z0-9-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 4
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "type": {
            "type": "string"
          },
          "accessed": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        }
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "id"],
        "properties": {
          "type": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "id": {
            "type": "string",
            "pattern": "^((article|topic):[a-z0-9-]+|claim-[0-9]{3}|source-[a-z0-9-]+)$"
          }
        }
      }
    },
    "agentInstructions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "accepted": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["rule", "rationale", "documentedAt"],
            "properties": {
              "rule": {
                "type": "string"
              },
              "scope": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                ]
              },
              "rationale": {
                "type": "string"
              },
              "documentedAt": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              }
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["createdAt", "createdBy", "agents", "reviews", "policy"],
      "properties": {
        "createdAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "createdBy": {
          "type": "string"
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["role", "model", "invokedAt", "inputHash", "outputHash"],
            "properties": {
              "role": {
                "type": "string"
              },
              "model": {
                "type": "string"
              },
              "invokedAt": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "inputHash": {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$"
              },
              "outputHash": {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$"
              }
            }
          }
        },
        "reviews": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["reviewer", "reviewedAt", "status", "scope", "notes"],
            "properties": {
              "reviewer": {
                "type": "string"
              },
              "reviewedAt": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "status": {
                "type": "string",
                "enum": ["approved", "requested-changes", "commented", "rejected"]
              },
              "scope": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "notes": {
                "type": "string"
              },
              "contentHash": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          }
        },
        "policy": {
          "type": "object",
          "additionalProperties": true,
          "required": ["id", "version"],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^policy:[a-z0-9-]+$"
            },
            "version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            }
          }
        }
      }
    },
    "contentHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
