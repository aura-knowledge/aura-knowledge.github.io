{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://v-i-s-h-a-l.github.io/knowledge/schemas/policy.schema.json",
  "title": "Aura Knowledge Publishing Policy",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "version", "name", "effectiveAt", "rules"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^policy:[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "name": {
      "type": "string",
      "minLength": 4
    },
    "effectiveAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "description": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "scope", "requirement"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "scope": {
            "type": "string",
            "enum": ["publication", "provenance", "claims", "sources", "review"]
          },
          "requirement": {
            "type": "string",
            "minLength": 8
          }
        }
      }
    }
  }
}
